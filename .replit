modules = ["nodejs-24", "python-base-3.13", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-server-tests"

[[workflows.workflow]]
name = "api-server-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[userenv]

[userenv.shared]
CLOUDFLARE_ACCOUNT_ID = "10d889165e3efc6e2a91667d0193c1bf"
SANITY_DATASET = "production"
SANITY_PROJECT_ID = "fupqvdcv"
SANITY_STUDIO_DATASET = "production"
SANITY_STUDIO_PROJECT_ID = "fupqvdcv"
NEXT_PUBLIC_SANITY_DATASET = "production"
NEXT_PUBLIC_SANITY_PROJECT_ID = "fupqvdcv"

[nix]
channel = "stable-25_05"
